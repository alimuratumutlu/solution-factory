{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alimuratumutlu/solution-factory/schema/pipeline.schema.json",
  "title": "Solution Factory Goal Pipeline",
  "type": "object",
  "required": ["version", "name", "nodes", "edges"],
  "properties": {
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "settings": {
      "type": "object",
      "properties": {
        "spiritualSupport": {
          "$ref": "#/$defs/spiritualSupportSettings"
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type", "label"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": [
            "intake",
            "ai_questions",
            "reflection",
            "goal",
            "milestone",
            "action",
            "checkpoint",
            "decision",
            "risk",
            "spiritual_support",
            "view",
            "codex",
            "claude",
            "shell",
            "manual_gate",
            "qa_review",
            "release"
          ]
        },
        "label": {
          "type": "string"
        },
        "promptFile": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "workingDirectory": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "timeframe": {
          "type": "string"
        },
        "priority": {
          "enum": ["low", "medium", "high"]
        },
        "viewModes": {
          "type": "array",
          "items": {
            "enum": ["kanban", "timeline", "graph", "table", "pipeline"]
          }
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "spiritualPractices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/spiritualPractice"
          }
        },
        "success": {
          "type": "object",
          "properties": {
            "filesExist": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exitCode": {
              "type": "integer"
            }
          }
        }
      }
    },
    "spiritualSupportSettings": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "enum": ["off", "gentle", "integrated"]
        },
        "allowedTypes": {
          "type": "array",
          "items": {
            "enum": ["Esma", "Dua", "Dhikr"]
          }
        },
        "preferredTimes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
          }
        },
        "allowAiSuggestions": {
          "type": "boolean"
        },
        "showInSolutionMap": {
          "type": "boolean"
        },
        "createReminders": {
          "type": "boolean"
        }
      }
    },
    "spiritualPractice": {
      "type": "object",
      "required": ["id", "type", "label", "schedule"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": ["Esma", "Dua", "Dhikr"]
        },
        "label": {
          "type": "string"
        },
        "displayText": {
          "type": "string"
        },
        "transliteration": {
          "type": "string"
        },
        "intentions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "schedule": {
          "type": "object",
          "required": ["count"],
          "properties": {
            "days": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "timingLabel": {
              "type": "string"
            },
            "timeOfDay": {
              "type": ["string", "null"],
              "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
            },
            "count": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "source": {
          "type": "object",
          "properties": {
            "project": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "reviewStatus": {
              "enum": ["needs_religious_review", "reviewed", "user_defined"]
            }
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        }
      }
    }
  }
}
